{
  "manifest_version": 3,
  "name": "Twitter Sticky Notes",
  "version": "1.0.0",
  "description": "Attach sticky notes to Twitter user profiles and timelines.",
  "permissions": ["storage"],
  "host_permissions": ["*://*.twitter.com/*", "*://*.x.com/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open Sticky Notes",
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.twitter.com/*", "*://*.x.com/*"],
      "js": ["src/content.ts"]
    }
  ]
}
