{
  "manifest_version": 3,
  "name": "Username Sticky Notes",
  "version": "1.0.0",
  "description": "Attach sticky notes to user profiles and timelines across platforms.",
  "permissions": ["storage", "cookies"],
  "host_permissions": ["*://*.twitter.com/*", "*://*.x.com/*", "https://notes.hadealahmad.com/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open Sticky Notes",
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.twitter.com/*", "*://*.x.com/*"],
      "js": ["src/content.ts"]
    }
  ],
  "externally_connectable": {
    "matches": ["https://notes.hadealahmad.com/*"]
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  }
}
